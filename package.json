{
  "name": "empower-peer-to-peer",
  "version": "0.0.0",
  "description": "Feasibility spike: browser PWA where a leader drives a shared gallery experience for co-located peers over WebRTC (Trystero). Content + audio are device-local; the wire carries only control state.",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "start": "vite serve",
    "dev": "vite serve",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "sim": "node test/model-sim.ts"
  },
  "dependencies": {
    "@trystero-p2p/mqtt": "~0.25.2",
    "@trystero-p2p/torrent": "~0.25.2",
    "qrcode": "~1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "trystero": "~0.25.2"
  },
  "devDependencies": {
    "@types/qrcode": "~1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "~5.1.3",
    "typescript": "^5.9.3",
    "vite": "~7.3.1",
    "vite-plugin-pwa": "~1.2.0",
    "workbox-core": "~7.4.0",
    "workbox-expiration": "~7.4.0",
    "workbox-precaching": "~7.4.0",
    "workbox-routing": "~7.4.0",
    "workbox-strategies": "~7.4.0"
  }
}
